{
  "name": "icn-airport-sys-local2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "//": "── 시설 QR CSV (public/NNN.csv 추가만, package.json 수정 불필요) ──",
    "dev": "vue-cli-service serve",
    "dev:csv": "node scripts/facility-csv.js dev",
    "//dev:csv": "pnpm dev:csv [004]  → public/004.csv 로 개발 (미지정 시 003.csv)",
    "build": "vue-cli-service build --no-module && node scripts/fix-index.js",
    "build:csv": "node scripts/facility-csv.js build",
    "//build:csv": "pnpm build:csv [004]  → CSV 번들 포함 빌드 (fix-index.js)",
    "facility-csv": "node scripts/facility-csv.js",
    "//facility-csv": "pnpm facility-csv list  → 사용 가능 CSV 목록",
    "build:modern": "vue-cli-service build",
    "build:csv:deploy": "node scripts/copy-dist.js",
    "lint": "vue-cli-service lint",
    "lint:fix": "vue-cli-service lint --fix",
    "format": "prettier --write \"src/**/*.{js,vue,json}\""
  },
  "dependencies": {
    "core-js": "^3.8.3",
    "date-fns": "2.30.0",
    "lodash.debounce": "^4.0.8",
    "vue": "^2.6.14",
    "vue-i18n": "8.28.2",
    "vue-infinite-loading": "^2.4.5",
    "vue-router": "^3.6.5",
    "vuex": "^3.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-vue": "^8.0.3",
    "postcss": "^8.5.6",
    "prettier": "^2.8.8",
    "tailwindcss": "2.2.19",
    "vue-template-compiler": "^2.6.14"
  },
  "browserslist": [
    "Chrome >= 66",
    "Android >= 9",
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
